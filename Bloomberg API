import blpapi
import pandas as pd

ISINs = [
    "XS2894149595",
    "XS2886113278",
    "XS3202703834",
    "XS2853493117",
    "XS3184844226",
    "XS3224207657",
    "XS3275877143",
]

def isin_to_bbg(isins: list[str]) -> pd.DataFrame:
    """
    Look up BBG Ticker, Description, and Underlying for a list of ISINs.
    Requires Bloomberg Terminal + blpapi installed.
    """
    session = blpapi.Session()
    session.start()
    session.openService("//blp/refdata")
    refdata = session.getService("//blp/refdata")

    request = refdata.createRequest("ReferenceDataRequest")

    # Add ISINs — Bloomberg accepts ISIN with /ISIN suffix
    for isin in isins:
        request.append("securities", f"/isin/{isin}")

    # Fields we want
    request.append("fields", "TICKER")           # BBG Ticker
    request.append("fields", "SECURITY_NAME")    # Description
    request.append("fields", "EQY_PRIM_SECURITY_TICKER")  # Underlying equity ticker
    request.append("fields", "CRNCY")            # Currency
    request.append("fields", "ID_BB_GLOBAL")     # FIGI identifier

    session.sendRequest(request)

    rows = []
    while True:
        event = session.nextEvent(500)
        for msg in event:
            if msg.hasElement("securityData"):
                sec_data = msg.getElement("securityData")
                for i in range(sec_data.numValues()):
                    s = sec_data.getValue(i)
                    isin_id = s.getElementAsString("security")
                    fields  = s.getElement("fieldData")

                    rows.append({
                        "ISIN":        isin_id.replace("/isin/", ""),
                        "BBG_Ticker":  fields.getElementAsString("TICKER"),
                        "Description": fields.getElementAsString("SECURITY_NAME"),
                        "Underlying":  fields.getElementAsString("EQY_PRIM_SECURITY_TICKER"),
                        "CCY":         fields.getElementAsString("CRNCY"),
                    })
        if event.eventType() == blpapi.Event.RESPONSE:
            break

    session.stop()
    return pd.DataFrame(rows)


df = isin_to_bbg(ISINs)
print(df.to_string(index=False))
df.to_csv("isin_lookup.csv", index=False)
